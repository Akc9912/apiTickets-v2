
# ==============================================
# PLANTILLA DE VARIABLES DE ENTORNO (.env.example)
# ApiTickets - Sistema de Gestión de Tickets
# Copia este archivo como .env y configura tus propios valores
# ==============================================

# BASE DE DATOS
DB_URL=jdbc:mysql://localhost:3306/apiticket?useSSL=false&serverTimezone=UTC
DB_USER=usuario
DB_PASS=contraseña

# JPA / HIBERNATE
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# JWT Y SEGURIDAD
JWT_SECRET=miSuperSecretoSeguro
JWT_EXPIRATION_MS=36000000
APP_DEFAULT_PASSWORD=defaultPass123

# SPRING Y PERFILES
SPRING_PROFILES_ACTIVE=mysql

# LOGGING
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_POO_MIAPI=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=INFO

# SERVIDOR
SERVER_PORT=8080

# SUBIDAS DE ARCHIVOS
FILE_UPLOAD_MAX_SIZE=10MB

# CORS (opcional)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# ==============================================
# CONFIGURACIÓN DE DESARROLLO/PRODUCCIÓN
# ==============================================
SPRING_PROFILES_ACTIVE=mysql
DEBUG_MODE=true

# Configuración de archivos subidos
FILE_UPLOAD_MAX_SIZE=10MB
FILE_UPLOAD_PATH=uploads/

# ==============================================
# CONFIGURACIÓN DE CACHE (Redis - opcional)
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=false
